###############################################################################
# Banked SRAM Controller
#
# Generic RTL Synthesis
###############################################################################

#----------------------------------------------------------
# Read RTL
#----------------------------------------------------------

script generated/read_rtl.ys

#----------------------------------------------------------
# Elaborate
#----------------------------------------------------------

hierarchy -check -top banked_sram_ctrl

#----------------------------------------------------------
# Convert Processes
#----------------------------------------------------------

proc

#----------------------------------------------------------
# FSM Extraction
#----------------------------------------------------------

fsm

#----------------------------------------------------------
# Memory Inference
#----------------------------------------------------------

memory

#----------------------------------------------------------
# Generic Optimizations
#----------------------------------------------------------

opt

#----------------------------------------------------------
# Sanity Checks
#----------------------------------------------------------

check

#----------------------------------------------------------
# Statistics
#----------------------------------------------------------

stat

#----------------------------------------------------------
# Generic Netlist
#----------------------------------------------------------

write_verilog netlists/banked_sram_ctrl_generic.v